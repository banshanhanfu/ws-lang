# ws-lang на русском
задача: обработка-изображений
  шаг: загрузить
    возможность: ws-storage
    вход: s3://uploads/raw/
    -> выход: изображения
  шаг: сжать
    возможность: ws-image
    вход: $изображения
    аргументы: { формат: webp, качество: 80 }
    при_ошибке: повторить(3, 5)
  шаг: уведомить
    возможность: ws-wechat
    вход: $сжать
    аргументы: { получатель: группа-дизайна }
