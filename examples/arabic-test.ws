# ws-lang بالعربية
مهمة: معالجة-الصور
  خطوة: تحميل
    قدرة: ws-storage
    مدخل: s3://uploads/raw/
    -> مخرج: صور
  خطوة: ضغط
    قدرة: ws-image
    مدخل: $صور
    وسائط: { تنسيق: webp, جودة: 80 }
    عند_الخطأ: إعادة_محاولة(3, 5)
  خطوة: إشعار
    قدرة: ws-wechat
    مدخل: $ضغط
    وسائط: { وجهة: مجموعة-التصميم }
