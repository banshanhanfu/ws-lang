# ws-lang हिंदी में
कार्य: छवि-प्रसंस्करण
  चरण: डाउनलोड
    क्षमता: ws-storage
    इनपुट: s3://uploads/raw/
    -> आउटपुट: छवियाँ
  चरण: संपीड़ित
    क्षमता: ws-image
    इनपुट: $छवियाँ
    तर्क: { प्रारूप: webp, गुणवत्ता: 80 }
    त्रुटि_पर: पुनः_प्रयास(3, 5)
  चरण: सूचित
    क्षमता: ws-wechat
    इनपुट: $संपीड़ित
    तर्क: { गंतव्य: डिज़ाइन-समूह }
